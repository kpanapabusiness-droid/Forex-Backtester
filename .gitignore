# Local outputs
# Use `results/*` (not `results/`) so per-directory exceptions can negate it;
# git refuses to re-include children if the parent dir itself is excluded.
results/*
# KH-24 artefacts are tracked (production system results — see results/kh24/audit/PHASE_KH24_PROMOTION.md)
!results/kh24/
!results/kh24/**
# v1.3 capturability calibration — read-only analysis output, tracked so
# the chat can read CALIBRATION_REPORT.md when locking v1.3 floors
!results/v1_3_calibration/
!results/v1_3_calibration/**
# v2.0 archetype clustering diagnostic — path-shape evidence-gathering
# on KH-24 + Arc 1 + Arc 2 (diagnostic only; no protocol revision)
!results/v2_0_diagnostic/
!results/v2_0_diagnostic/**
# v2.0 predictability investigation — entry-time + t>0 angles on
# target archetypes from PR #129 (diagnostic only; no protocol revision)
!results/v2_0_predictability/
!results/v2_0_predictability/**
# KH-24 v2.0 self-test arc — Step 1+ outputs (L_ARC_PROTOCOL v2.0 §13: arc
# results data is direct-to-main).
!results/arc_kh24_v2/
!results/arc_kh24_v2/**
# Arc 3 (L registry Entry 3: d1_atr_top_decile, h_120) — Step 1+ outputs
# (L_ARC_PROTOCOL v2.0 §13: arc results data is direct-to-main).
!results/l_arc_3/
!results/l_arc_3/**
# Arc 2 redo (CLOSED 2026-05-16 KILL at Step 3) — track the result doc;
# step1/2/3 CSVs/PNGs stay local per minimal-track convention.
!results/l_arc_2_redo/
results/l_arc_2_redo/*
!results/l_arc_2_redo/ARC_2_REDO_RESULT.md
# Arc 2 redo2 (OPEN; v2.1.1) — Step 1+ outputs (L_ARC_PROTOCOL v2.1.1 §13: arc
# results data is direct-to-main). Track summaries / audits / small CSVs;
# trades_paths.csv excluded (>100MB GitHub limit; regenerable from script + config).
!results/l_arc_2_redo2/
!results/l_arc_2_redo2/**
results/l_arc_2_redo2/**/trades_paths.csv
results/l_arc_2_redo2/**/_run_log.txt
# v2.1.1 Open-18 empirical replays (per-cohort: arc_3_stepwise, kh24_v2_c4,
# arc_2_redo_c2). Track all small CSVs + REPLAY_RESULT.md; exclude the large
# regenerable forward-extended paths CSV (~40-50MB per cohort; rebuildable
# from extend_paths.py + the source arc's step1 data).
!results/replays_v2_1_1/
!results/replays_v2_1_1/**
results/replays_v2_1_1/**/trades_paths_extended.csv
results_phase*/
__pycache__/
.ipynb_checkpoints/

